DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:<db-port>/food_recommendation_system
# Docker entrypoint: 1 = run init.py on startup (destructive). Usually 0 after first bootstrap.
RUN_INIT=0
JWT_KEY=<secret-key>

EMBEDDING_DIM=32
EPOCHS=5
LEARNING_RATE=0.001

# These should sum to ~1.0
W_NCF=0.5
W_SVD=0.3
W_CONTENT=0.1
W_POPULARITY=0.1

ADMIN_API_KEY=<admin-secret>
